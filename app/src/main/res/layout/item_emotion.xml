<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/crdEmotion"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:ignore="MissingConstraints">

        <androidx.cardview.widget.CardView
            app:cardCornerRadius="18dp"
            android:layout_margin="1dp"
            app:cardElevation="0dp"
            android:backgroundTint="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:ignore="MissingConstraints">

            <LinearLayout
                android:layout_margin="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    android:id="@+id/crdEmotionBackground"
                    app:cardCornerRadius="10dp"
                    android:backgroundTint="#f2f7ea"
                    app:cardElevation="0dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgEmotion"
                        android:layout_margin="10dp"
                        android:src="@drawable/ic_happy"
                        android:layout_width="20dp"
                        android:layout_height="20dp"/>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_marginTop="5dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_color_gray"
                    android:fontFamily="@font/man_bold"
                    android:text="Happy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_gray"
                    android:fontFamily="@font/man_reg"
                    android:text="Joyful,grateful"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>


        </androidx.cardview.widget.CardView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>