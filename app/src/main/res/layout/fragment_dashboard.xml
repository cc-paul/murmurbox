<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/light_blue"
    tools:context="com.pagshq.murmurbox.fragment.DashboardFragment">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:fillViewport="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_margin="15dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_marginTop="15dp"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <TextView
                                android:textSize="20sp"
                                android:fontFamily="@font/man_semi"
                                android:text="MurmurBox"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:textColor="@color/text_gray"
                                android:textSize="13sp"
                                android:fontFamily="@font/man_reg"
                                android:text="Good Afternoon - Apr 15, 2026"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>

                        <Space
                            android:layout_weight="1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <LinearLayout
                            android:backgroundTint="@color/black"
                            android:background="@drawable/layout_bg"
                            android:layout_width="50dp"
                            android:layout_height="match_parent">

                            <TextView
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:text="PE"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginTop="20dp"
                        android:weightSum="2"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">


                        </androidx.cardview.widget.CardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent"/>

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">


                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginBottom="20dp"
                        android:layout_marginTop="20dp"
                        android:weightSum="2"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">


                        </androidx.cardview.widget.CardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent"/>

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0.5dp"
                        android:layout_margin="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="300dp">

                        <LinearLayout
                            android:layout_margin="20dp"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <TextView
                                android:textColor="@color/text_gray"
                                android:textSize="13sp"
                                android:fontFamily="@font/man_semi"
                                android:text="EMOTION TREND"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:weightSum="2"
                        android:layout_marginTop="20dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_weight="1"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp"
                            android:fontFamily="@font/man_semi"
                            android:text="RECENT RECORDINGS"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:gravity="end"
                            android:layout_weight="1"
                            android:textColor="@color/medium_blue"
                            android:textSize="13sp"
                            android:fontFamily="@font/man_semi"
                            android:text="See all"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

<!--                    Recent Recording View Here-->

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="100dp"/>

                </LinearLayout>

            </ScrollView>

            <androidx.cardview.widget.CardView
                android:id="@+id/crdNew"
                android:backgroundTint="@color/dark_blue"
                app:cardCornerRadius="30dp"
                android:layout_margin="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true">

                <LinearLayout
                    android:layout_margin="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_mic_white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:gravity="center_vertical"
                        android:textColor="@color/white"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/man_semi"
                        android:text="New Murmur" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>
            
        </RelativeLayout>


        <LinearLayout
            android:padding="2dp"
            android:weightSum="3"
            android:background="@color/white"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <LinearLayout
                android:gravity="center"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:fontFamily="@font/man_semi"
                    android:text="Dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lnNew"
                android:gravity="center"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_mic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textColor="@color/text_gray_2"
                    android:fontFamily="@font/man_semi"
                    android:text="Record"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <LinearLayout
                android:gravity="center"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_history"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textColor="@color/text_gray_2"
                    android:fontFamily="@font/man_semi"
                    android:text="History"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>