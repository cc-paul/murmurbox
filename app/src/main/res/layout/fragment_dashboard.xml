<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/light_blue"
    tools:context=".fragment.DashboardFragment">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:fillViewport="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_margin="15dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_marginTop="15dp"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <TextView
                                android:textSize="20sp"
                                android:fontFamily="@font/man_semi"
                                android:text="MurmurBox"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:textColor="@color/text_gray_2"
                                android:textSize="13sp"
                                android:fontFamily="@font/man_reg"
                                android:text="Good Afternoon - Apr 15, 2026"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>

                        <Space
                            android:layout_weight="1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <LinearLayout
                            android:backgroundTint="@color/black"
                            android:background="@drawable/layout_bg"
                            android:layout_width="50dp"
                            android:layout_height="match_parent">

                            <TextView
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:text="PE"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginTop="20dp"
                        android:weightSum="2"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">


                        </androidx.cardview.widget.CardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent"/>

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">


                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginBottom="20dp"
                        android:layout_marginTop="20dp"
                        android:weightSum="2"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">


                        </androidx.cardview.widget.CardView>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent"/>

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0.5dp"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:layout_width="wrap_content"
                            android:layout_height="150dp">

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0.5dp"
                        android:layout_margin="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="300dp">

                        <LinearLayout
                            android:layout_margin="20dp"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <TextView
                                android:textColor="@color/text_gray_2"
                                android:textSize="13sp"
                                android:fontFamily="@font/man_semi"
                                android:text="EMOTION TREND"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:weightSum="2"
                        android:layout_marginTop="20dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_weight="1"
                            android:textColor="@color/text_gray_2"
                            android:textSize="13sp"
                            android:fontFamily="@font/man_semi"
                            android:text="RECENT RECORDINGS"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:gravity="end"
                            android:layout_weight="1"
                            android:textColor="@color/medium_blue"
                            android:textSize="13sp"
                            android:fontFamily="@font/man_semi"
                            android:text="See all"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

            <androidx.cardview.widget.CardView
                android:backgroundTint="@color/dark_blue"
                app:cardCornerRadius="30dp"
                android:layout_margin="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true">

                <LinearLayout
                    android:layout_margin="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_mic_white"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:gravity="center_vertical"
                        android:textColor="@color/white"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/man_semi"
                        android:text="New Murmur" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>
            
        </RelativeLayout>


        <LinearLayout
            android:padding="2dp"
            android:weightSum="3"
            android:background="@color/white"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <LinearLayout
                android:gravity="center"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:fontFamily="@font/man_semi"
                    android:text="Dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <LinearLayout
                android:gravity="center"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_mic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textColor="@color/text_gray_2"
                    android:fontFamily="@font/man_semi"
                    android:text="Record"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <LinearLayout
                android:gravity="center"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_history"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textColor="@color/text_gray_2"
                    android:fontFamily="@font/man_semi"
                    android:text="History"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>





    <ScrollView
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_margin="30dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/man_bold"
                android:text="murmurbox"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/man_semi"
                android:letterSpacing="0.3"
                android:text="GOOD EVENING"
                android:textColor="@color/text_color_gray"
                android:textStyle="bold" />

            <TextView
                android:textStyle="bold"
                android:fontFamily="@font/man_bold"
                android:textSize="25sp"
                android:text="How are you"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:textStyle="bold"
                android:fontFamily="@font/man_bold"
                android:textSize="25sp"
                android:text="feeling today?"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_margin="20dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/man_semi"
                        android:letterSpacing="0.3"
                        android:text="THIS MONTH"
                        android:textColor="@color/text_color_gray"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_marginTop="10dp"
                        android:weightSum="3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="match_parent">

                            <TextView
                                android:fontFamily="@font/man_bold"
                                android:textSize="35sp"
                                android:text="0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/man_semi"
                                android:text="murmurs"
                                android:textColor="@color/text_color_gray"
                                android:textStyle="bold" />

                        </LinearLayout>


                        <LinearLayout
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:background="@color/text_color_gray"
                            android:layout_width="1dp"
                            android:layout_height="match_parent"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="match_parent">

                            <TextView
                                android:fontFamily="@font/man_bold"
                                android:textSize="35sp"
                                android:text="0"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/man_semi"
                                android:text="emotions"
                                android:textColor="@color/text_color_gray"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:background="@color/text_color_gray"
                            android:layout_width="1dp"
                            android:layout_height="match_parent"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="match_parent">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/crdEmotionBackground"
                                app:cardCornerRadius="10dp"
                                android:backgroundTint="#f2f7ea"
                                app:cardElevation="0dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <ImageView
                                    android:id="@+id/imgEmotion"
                                    android:layout_margin="10dp"
                                    android:src="@drawable/circle_gray"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"/>

                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_marginTop="5dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/man_semi"
                                android:text="average emotion"
                                android:textColor="@color/text_color_gray"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginTop="10dp"
                        android:weightSum="2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_marginEnd="5dp"
                            android:src="@drawable/circle"
                            android:layout_width="10dp"
                            android:layout_height="match_parent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/man_bold"
                            android:text="0 day streak"
                            android:textSize="14sp"
                            android:textColor="@color/streak"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/crdNew"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp"
                android:backgroundTint="@color/button_bg"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <TextView
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:fontFamily="@font/man_bold"
                    android:textSize="17sp"
                    android:text="+ new murmur"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/man_semi"
                android:letterSpacing="0.1"
                android:text="RECENT"
                android:textColor="@color/text_color_gray"
                android:textStyle="bold" />

            <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/empty_murmur"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"/>

                <TextView
                    android:textStyle="bold"
                    android:fontFamily="@font/man_bold"
                    android:textSize="25sp"
                    android:text="Your box is empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/man_semi"
                    android:letterSpacing="0.1"
                    android:text="You haven't recorded anything yet.\nSpeak your first feeling."
                    android:textColor="@color/text_color_gray"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>