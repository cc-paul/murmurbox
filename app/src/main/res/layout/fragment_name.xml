<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary"
    tools:context=".fragment.NameFragment">

    <LinearLayout
        android:layout_margin="30dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:letterSpacing="0.2"
            android:textSize="16sp"
            android:textColor="@color/text_color_gray"
            android:textStyle="bold"
            android:fontFamily="@font/man_semi"
            android:text="WELCOME"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:textStyle="bold"
            android:fontFamily="@font/man_bold"
            android:textSize="30sp"
            android:text="What should"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:textStyle="bold"
            android:fontFamily="@font/man_bold"
            android:textSize="30sp"
            android:text="we call you?"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="This is just for you — your"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="space, your name, your way."
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


        <TextView
            android:layout_marginTop="50dp"
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="YOUR NAME"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/layout_bg">

            <EditText
                android:hint="e.g. Alex"
                android:id="@+id/etName"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:ems="10"
                android:fontFamily="@font/man_semi"
                android:inputType="textNoSuggestions|text"
                android:maxLines="1"
                android:paddingStart="10sp"
                android:paddingEnd="10sp"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

        </LinearLayout>

        <TextView
            android:layout_marginTop="5dp"
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="this stays on your device only"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Space
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <androidx.cardview.widget.CardView
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:backgroundTint="@color/button_border"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:id="@+id/crdContinue"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                android:layout_margin="1dp"
                android:backgroundTint="@color/primary"
                android:layout_width="match_parent"
                android:layout_height="35dp">

                <TextView
                    android:gravity="center"
                    android:textStyle="bold"
                    android:fontFamily="@font/man_bold"
                    android:textSize="15sp"
                    android:text="continue"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </androidx.cardview.widget.CardView>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</FrameLayout>