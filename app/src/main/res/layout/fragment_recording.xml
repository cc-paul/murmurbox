<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/primary"
    android:layout_height="match_parent"
    tools:context=".fragment.RecordingFragment">

    <LinearLayout
        android:layout_margin="30dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvBack"
            android:textSize="16sp"
            android:textColor="@color/text_color_gray"
            android:textStyle="bold"
            android:fontFamily="@font/man_semi"
            android:text="&lt; back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <androidx.cardview.widget.CardView
            android:layout_marginTop="20dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/imgEmotionStatus"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/circle_gray"
                    android:layout_width="10dp"
                    android:layout_height="match_parent"/>

                <TextView
                    android:id="@+id/tvSelectedEmotion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/man_bold"
                    android:text="Selected Emotion"
                    android:textSize="14sp"
                    android:textColor="@color/text_gray"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:textStyle="bold"
            android:fontFamily="@font/man_bold"
            android:textSize="30sp"
            android:text="Why do you feel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:textStyle="bold"
            android:fontFamily="@font/man_bold"
            android:textSize="30sp"
            android:text="this way?"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="speak freely — only you can hear this"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.cardview.widget.CardView
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_margin="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <LinearLayout
                    android:id="@+id/waveContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/bar1"
                        android:layout_width="2dp"
                        android:layout_height="30dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar2"
                        android:layout_width="2dp"
                        android:layout_height="35dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar3"
                        android:layout_width="2dp"
                        android:layout_height="32dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar4"
                        android:layout_width="2dp"
                        android:layout_height="40dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar5"
                        android:layout_width="2dp"
                        android:layout_height="33dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar6"
                        android:layout_width="2dp"
                        android:layout_height="45dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar7"
                        android:layout_width="2dp"
                        android:layout_height="38dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar8"
                        android:layout_width="2dp"
                        android:layout_height="50dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar9"
                        android:layout_width="2dp"
                        android:layout_height="36dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                    <View
                        android:id="@+id/bar10"
                        android:layout_width="2dp"
                        android:layout_height="34dp"
                        android:layout_marginHorizontal="1dp"
                        android:background="@drawable/bar_wave" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvRecordDuration"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:textStyle="bold"
            android:fontFamily="@font/man_bold"
            android:textSize="40sp"
            android:text="0:0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvRecordStatus"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="record not started"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Space
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:weightSum="3"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/lnPlayPause"
                android:alpha="0.4"
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

                <LinearLayout
                    android:gravity="center"
                    android:background="@drawable/circle_white_bg"
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <ImageView
                        android:id="@+id/imgPlayPause"
                        android:src="@drawable/ic_play"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/lnStartStopSaveRecord"
                    android:gravity="center"
                    android:background="@drawable/circle_record"
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <ImageView
                        android:id="@+id/imgStartStopSaveRecord"
                        android:src="@drawable/circle_white_bg"
                        android:layout_width="20dp"
                        android:layout_height="20dp"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lnDelete"
                android:alpha="0.4"
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

                <LinearLayout
                    android:gravity="center"
                    android:background="@drawable/circle_white_bg"
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <ImageView
                        android:src="@drawable/ic_trash"
                        android:layout_width="20dp"
                        android:layout_height="match_parent"/>

                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

        <TextView
            android:id="@+id/tvRecordReminder"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="@color/text_color_gray"
            android:fontFamily="@font/man_semi"
            android:text="tap circle to start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</FrameLayout>